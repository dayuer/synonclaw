[Unit]
Description=OpenClaw GNB Bridge (socat)
After=gnb.service openclaw.service
Requires=gnb.service

[Service]
Type=simple
ExecStart=/usr/bin/socat \
  TCP-LISTEN:18789,bind=GNB_VIP_PLACEHOLDER,reuseaddr,fork \
  TCP:127.0.0.1:18789
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
